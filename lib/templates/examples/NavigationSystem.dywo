<script>
export default {
  name: 'NavigationSystem',
  data() {
    return {
      currentRoute: 'home',
      mobileOpen: false,
      links: [
        { label: 'Home', route: 'home' },
        { label: 'About', route: 'about' },
        { label: 'Services', route: 'services' },
        { label: 'Contact', route: 'contact' }
      ],
      services: [
        { icon: '&#9889;', title: 'Web Development', desc: 'Fast, lightweight web applications built with DYWO.' },
        { icon: '&#128640;', title: 'Performance', desc: 'Optimized builds with zero runtime overhead.' },
        { icon: '&#128736;', title: 'Consulting', desc: 'Expert guidance for your DYWO projects.' }
      ]
    };
  },
  methods: {
    navigate: function(route) {
      if (route) this.currentRoute = route;
    },
    toggleMobile: function() {
      this.mobileOpen = !this.mobileOpen;
    },
    closeMobile: function() {
      this.mobileOpen = false;
    },
    goHome: function() {
      this.currentRoute = 'home';
      this.mobileOpen = false;
    },
    noop: function() {}
  }
};
</script>
