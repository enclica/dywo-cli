<template>
  <div class="nav-app" dywo-system="navSystem">
    <nav class="navbar">
      <div class="navbar-inner">
        <a class="navbar-brand" href="#" dywo-on:click.prevent="goHome">
          <span class="brand-icon">&#9670;</span>
          <span class="brand-text">DYWO Nav</span>
        </a>

        <ul class="navbar-links">
          <li dywo-for="link in links">
            <a
              href="#"
              dywo-class="nav-link, active: currentRoute === link.route"
              dywo-trigger="navSystem:navigate"
              dywo-trigger-on="click"
              dywo-trigger-data="link.route"
              dywo-on:click.prevent="noop"
            >
              {{ link.label }}
            </a>
          </li>
        </ul>

        <button class="hamburger" dywo-on:click="toggleMobile" dywo-class="hamburger, open: mobileOpen">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <ul class="mobile-menu" dywo-show="mobileOpen">
        <li dywo-for="link in links">
          <a
            href="#"
            dywo-class="mobile-link, active: currentRoute === link.route"
            dywo-trigger="navSystem:navigate"
            dywo-trigger-on="click"
            dywo-trigger-data="link.route"
            dywo-on:click.prevent="closeMobile"
          >
            {{ link.label }}
          </a>
        </li>
      </ul>
    </nav>

    <main class="content" dywo-connect="navSystem" dywo-action="navigate">
      <div class="page" dywo-show="currentRoute === 'home'">
        <h1 class="page-title">Home</h1>
        <p class="page-desc">Welcome to the navigation system demo. Click the links above to switch routes.</p>
        <div class="page-card">
          <h3>How It Works</h3>
          <p>Nav links use <code>dywo-trigger</code> to emit route changes to the <code>navSystem</code>. The content area is connected via <code>dywo-connect</code> and receives the navigation action.</p>
        </div>
      </div>

      <div class="page" dywo-show="currentRoute === 'about'">
        <h1 class="page-title">About</h1>
        <p class="page-desc">This page demonstrates system-based navigation without a traditional router.</p>
        <div class="page-card">
          <h3>System Architecture</h3>
          <ul class="feature-list">
            <li><strong>dywo-system</strong> defines the navigation bus</li>
            <li><strong>dywo-trigger</strong> fires route change events from links</li>
            <li><strong>dywo-connect</strong> + <strong>dywo-action</strong> receives and handles navigation</li>
          </ul>
        </div>
      </div>

      <div class="page" dywo-show="currentRoute === 'services'">
        <h1 class="page-title">Services</h1>
        <p class="page-desc">Browse our services below.</p>
        <div class="services-grid">
          <div class="service-card" dywo-for="service in services">
            <span class="service-icon">{{ service.icon }}</span>
            <h3>{{ service.title }}</h3>
            <p>{{ service.desc }}</p>
          </div>
        </div>
      </div>

      <div class="page" dywo-show="currentRoute === 'contact'">
        <h1 class="page-title">Contact</h1>
        <p class="page-desc">Get in touch with us.</p>
        <div class="page-card">
          <div class="contact-info">
            <div class="contact-row">
              <span class="contact-label">Email</span>
              <span class="contact-value">hello@dywo.dev</span>
            </div>
            <div class="contact-row">
              <span class="contact-label">Location</span>
              <span class="contact-value">San Francisco, CA</span>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="footer">
      <p>Current route: <strong>{{ currentRoute }}</strong> &mdash; Navigation System Demo</p>
    </footer>
  </div>
</template>

