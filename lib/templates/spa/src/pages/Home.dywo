</style>

<script>
export default {
  name: 'Home',
  data() {
    return {
      title: 'Build the web, without the weight.',
      subtitle: 'DYWO is a lightweight framework and CLI that compiles your components into blazing-fast static sites. No bloat, no virtual DOM, just pure performance.',
      featuresIntro: 'Everything you need to build modern websites with minimal overhead and maximum developer experience.',
      stats: [
        { value: '~4kb', label: 'Runtime' },
        { value: '0', label: 'Dependencies' },
        { value: '100', label: 'Lighthouse' }
      ],
      features: [
        { icon: '&#9889;', title: 'single file components', desc: 'Write HTML, CSS, and JS together in intuitive .dywo files. No configuration headaches.', highlighted: false },
        { icon: '&#128640;', title: 'zero runtime overhead', desc: 'Tiny 4kb runtime with no virtual DOM. Your pages load instantly, every time.', highlighted: true },
        { icon: '&#128295;', title: 'modern tooling', desc: 'PostCSS, Babel, code splitting, and tree shaking built right in. Ship optimized code by default.', highlighted: false },
        { icon: '&#128260;', title: 'legacy migration', desc: 'Convert existing HTML, CSS, and JS sites into DYWO projects with a single command.', highlighted: false },
        { icon: '&#128736;', title: 'reactive data binding', desc: 'Two-way binding, computed properties, and event handling with a clean, declarative syntax.', highlighted: false },
        { icon: '&#128230;', title: 'built-in routing', desc: 'SPA routing with dynamic parameters, guards, and transitions out of the box.', highlighted: false }
      ],
      newTask: '',
      tasks: [
        { text: 'Learn DYWO basics', done: true },
        { text: 'Build a component', done: true },
        { text: 'Deploy to production', done: false }
      ]
    };
  },
  computed: {
    completedCount: function() {
      return this.tasks.filter(function(t) { return t.done; }).length;
    }
  },
  methods: {
    addTask: function() {
      var text = this.newTask.trim();
      if (!text) return;
      this.tasks.push({ text: text, done: false });
      this.newTask = '';
    },
    removeTask: function(e) {
      var index = this.tasks.indexOf(e.task);
      if (index > -1) this.tasks.splice(index, 1);
    },
    clearCompleted: function() {
      this.tasks = this.tasks.filter(function(t) { return !t.done; });
    }
  }
};
</script>
