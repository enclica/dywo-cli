<template>
  <div class="home">
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-content">
        <span class="hero-badge">v1.0 &mdash; Open Source</span>
        <h1 class="hero-title">{{ title }}</h1>
        <p class="hero-subtitle">{{ subtitle }}</p>
        <div class="hero-actions">
          <a href="/about" dywo-link class="btn btn-primary btn-lg">
            Get Started
            <span class="btn-arrow">&rarr;</span>
          </a>
          <a href="https://github.com/bluethefoxofficial/dywo-cli" target="_blank" rel="noopener" class="btn btn-ghost btn-lg">
            View on GitHub
          </a>
        </div>
        <div class="hero-stats">
          <div class="stat" dywo-for="stat in stats">
            <span class="stat-value">{{ stat.value }}</span>
            <span class="stat-label">{{ stat.label }}</span>
          </div>
        </div>
      </div>
    </section>

    <section class="features-section">
      <div class="section-header">
        <h2 class="section-title">Why DYWO?</h2>
        <p class="section-desc">{{ truncate(featuresIntro, 80) }}</p>
      </div>
      <div class="features-grid">
        <div
          dywo-for="feature in features"
          dywo-class="feature-card, featured: feature.highlighted"
        >
          <div class="feature-icon">{{ feature.icon }}</div>
          <h3 class="feature-title">{{ capitalize(feature.title) }}</h3>
          <p class="feature-desc">{{ feature.desc }}</p>
        </div>
      </div>
    </section>

    <section class="demo-section">
      <div class="section-header">
        <h2 class="section-title">See It In Action</h2>
        <p class="section-desc">A reactive task list, powered by DYWO.</p>
      </div>
      <div class="demo-card" dywo-system="todoApp">
        <div class="demo-input-row" dywo-connect="todoApp" dywo-action="addTask">
          <input
            type="text"
            dywo-bind:value="newTask"
            dywo-trigger="todoApp:addTask"
            dywo-trigger-on="keydown.enter"
            placeholder="Add a new task..."
            class="demo-input"
          />
          <button dywo-trigger="todoApp:addTask" class="btn btn-primary">Add</button>
        </div>
        <ul class="demo-list">
          <li
            dywo-for="task in tasks"
            dywo-class="demo-item, done: task.done"
          >
            <label class="demo-check">
              <input type="checkbox" dywo-bind:checked="task.done" />
              <span class="checkmark"></span>
              <span class="demo-text">{{ task.text }}</span>
            </label>
            <button dywo-on:click="removeTask" class="demo-remove">&times;</button>
          </li>
        </ul>
        <div dywo-show="tasks.length > 0" class="demo-footer">
          <span class="demo-count">{{ completedCount }} of {{ tasks.length }} completed</span>
          <button dywo-on:click="clearCompleted" dywo-show="completedCount > 0" class="btn btn-sm btn-ghost">
            Clear completed
          </button>
        </div>
        <div dywo-show="tasks.length === 0" class="demo-empty">
          No tasks yet. Add one above!
        </div>
      </div>
    </section>
  </div>
</template>

<style scoped>
